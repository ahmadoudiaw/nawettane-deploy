generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ONCAV_ADMIN
  ORCAV_ADMIN
  ODCAV_ADMIN
  ZONE_ADMIN
  GUICHET_AGENT
  AGENT_MAIRIE
  SUPPORTER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OrganizationType {
  ONCAV
  ORCAV
  ODCAV
  ZONE
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum MatchStatus {
  DRAFT
  PUBLISHED
  CLOSED
  CANCELLED
}

enum AssignmentType {
  SALES
  SCAN
  BOTH
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  EXPIRED
}

enum PaymentProvider {
  WAVE_MOCK
  ORANGE_MONEY_MOCK
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum TicketStatus {
  GENERATED
  USED
  CANCELLED
}

enum ScanResult {
  VALID
  ALREADY_USED
  INVALID
  OUT_OF_SCOPE
}

enum AgeCategory {
  CADET
  SENIOR
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

model Region {
  id            String         @id @default(cuid())
  name          String
  code          String?        @unique
  organizations Organization[]
  departments   Department[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("regions")
}

model Department {
  id            String         @id @default(cuid())
  name          String
  code          String?        @unique
  regionId      String
  region        Region         @relation(fields: [regionId], references: [id], onDelete: Restrict)
  communes      Commune[]
  organizations Organization[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([regionId])
  @@map("departments")
}

model Commune {
  id            String         @id @default(cuid())
  name          String
  code          String?        @unique
  departmentId  String
  department    Department     @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  organizations Organization[]
  venues        Venue[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([departmentId])
  @@map("communes")
}

model Organization {
  id                     String                       @id @default(cuid())
  name                   String
  type                   OrganizationType
  parentId               String?
  regionId               String?
  departmentId           String?
  communeId              String?
  status                 OrganizationStatus          @default(ACTIVE)
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  parent                 Organization?               @relation("OrganizationHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children               Organization[]              @relation("OrganizationHierarchy")
  region                 Region?                     @relation(fields: [regionId], references: [id], onDelete: Restrict)
  department             Department?                 @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  commune                Commune?                    @relation(fields: [communeId], references: [id], onDelete: Restrict)
  userAssignments        UserOrganizationAssignment[]
  venues                 Venue[]
  teams                  Team[]
  hostedMatches          Match[]
  zoneAssignments        ZoneAgentAssignment[]
  payouts                Payout[]

  @@index([type])
  @@index([parentId])
  @@index([regionId])
  @@index([departmentId])
  @@index([communeId])
  @@unique([parentId, name, type])
  @@map("organizations")
}

model Season {
  id        String   @id @default(cuid())
  name      String
  year      Int
  active    Boolean  @default(false)
  matches   Match[]
  payouts   Payout[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, name])
  @@index([active])
  @@map("seasons")
}

model User {
  id                      String                       @id @default(cuid())
  fullName                String
  phone                   String                       @unique
  email                   String?                      @unique
  passwordHash            String?
  role                    Role
  status                  UserStatus                   @default(ACTIVE)
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt
  organizationAssignments UserOrganizationAssignment[]
  zoneAssignments         ZoneAgentAssignment[]
  matchAssignments        MatchAssignment[]
  scans                   TicketScan[]
  createdMatches          Match[]                      @relation("MatchCreatedBy")
  cancelledTickets        Ticket[]                     @relation("TicketCancelledBy")
  auditLogs               AuditLog[]
  supporterProfile        SupporterProfile?

  @@index([role])
  @@index([status])
  @@map("users")
}

model UserOrganizationAssignment {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  isPrimary      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId, isPrimary])
  @@map("user_organization_assignments")
}

model Venue {
  id             String              @id @default(cuid())
  organizationId String?
  communeId      String?
  name           String
  address        String?
  capacity       Int?
  status         OrganizationStatus  @default(ACTIVE)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization?       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  commune        Commune?            @relation(fields: [communeId], references: [id], onDelete: Restrict)
  matches        Match[]

  @@index([organizationId])
  @@index([communeId])
  @@map("venues")
}

model Team {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  category       AgeCategory  @default(SENIOR)
  status         OrganizationStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  homeMatches    Match[]      @relation("HomeTeam")
  awayMatches    Match[]      @relation("AwayTeam")

  @@unique([organizationId, name, category])
  @@index([organizationId])
  @@map("teams")
}

model Match {
  id                String              @id @default(cuid())
  seasonId          String
  organizationId    String
  venueId           String
  homeTeamId        String
  awayTeamId        String
  competitionName   String
  category          AgeCategory         @default(SENIOR)
  stage             String?
  matchDate         DateTime
  status            MatchStatus         @default(DRAFT)
  ticketPrice       Decimal             @db.Decimal(12, 2)
  ticketQuota       Int?
  createdById       String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  season            Season              @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  organization      Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  venue             Venue               @relation(fields: [venueId], references: [id], onDelete: Restrict)
  homeTeam          Team                @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam          Team                @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  createdBy         User                @relation("MatchCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  ticketCategories  MatchTicketCategory[]
  orders            Order[]
  tickets           Ticket[]
  assignments       MatchAssignment[]
  scans             TicketScan[]

  @@index([seasonId, organizationId])
  @@index([organizationId, matchDate])
  @@index([status, matchDate])
  @@map("matches")
}

model MatchTicketCategory {
  id         String   @id @default(cuid())
  matchId     String
  name        String
  price       Decimal  @db.Decimal(12, 2)
  quota       Int?
  soldCount   Int      @default(0)
  badgeColor  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  orders      Order[]
  tickets     Ticket[]

  @@unique([matchId, name])
  @@index([matchId])
  @@map("match_ticket_categories")
}

model MatchAssignment {
  id             String         @id @default(cuid())
  matchId        String
  userId         String
  assignmentType AssignmentType
  createdAt      DateTime       @default(now())
  match          Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([userId])
  @@map("match_assignments")
}

model ZoneAgentAssignment {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  assignmentType AssignmentType
  createdAt      DateTime       @default(now())
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("zone_agent_assignments")
}

model SupporterProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  fullName  String
  phone     String
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([phone])
  @@map("supporter_profiles")
}

model Order {
  id               String      @id @default(cuid())
  reference        String      @unique
  supporterId      String?
  matchId          String
  ticketCategoryId String
  buyerName        String
  buyerPhone       String
  buyerEmail       String?
  quantity         Int
  unitPrice        Decimal     @db.Decimal(12, 2)
  totalAmount      Decimal     @db.Decimal(12, 2)
  status           OrderStatus @default(PENDING)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  supporter        SupporterProfile? @relation(fields: [supporterId], references: [id], onDelete: SetNull)
  match            Match       @relation(fields: [matchId], references: [id], onDelete: Restrict)
  ticketCategory   MatchTicketCategory @relation(fields: [ticketCategoryId], references: [id], onDelete: Restrict)
  payments         Payment[]
  tickets          Ticket[]

  @@index([matchId])
  @@index([ticketCategoryId])
  @@index([supporterId])
  @@index([status, createdAt])
  @@map("orders")
}

model Payment {
  id                String          @id @default(cuid())
  orderId           String
  provider          PaymentProvider
  providerReference String?         @unique
  amount            Decimal         @db.Decimal(12, 2)
  status            PaymentStatus   @default(PENDING)
  paidAt            DateTime?
  rawPayload        Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  order             Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([provider, status])
  @@map("payments")
}

model Ticket {
  id          String       @id @default(cuid())
  orderId     String
  matchId     String
  ticketCategoryId String
  ticketCode  String       @unique
  qrPayload   String
  status      TicketStatus @default(GENERATED)
  holderName  String?
  usedAt      DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  match       Match        @relation(fields: [matchId], references: [id], onDelete: Restrict)
  ticketCategory MatchTicketCategory @relation(fields: [ticketCategoryId], references: [id], onDelete: Restrict)
  cancelledAt          DateTime?
  cancelledByAdminId   String?
  cancelReason         String?
  cancelledByAdmin     User?        @relation("TicketCancelledBy", fields: [cancelledByAdminId], references: [id], onDelete: SetNull)
  scans                TicketScan[]

  @@index([matchId])
  @@index([orderId])
  @@index([ticketCategoryId])
  @@index([status])
  @@index([cancelledByAdminId])
  @@map("tickets")
}

model TicketScan {
  id          String     @id @default(cuid())
  ticketId    String
  matchId     String
  scannedById String
  scanResult  ScanResult
  scannedAt   DateTime   @default(now())
  deviceLabel String?
  ticket      Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  match       Match      @relation(fields: [matchId], references: [id], onDelete: Restrict)
  scannedBy   User       @relation(fields: [scannedById], references: [id], onDelete: Restrict)

  @@index([ticketId, scannedAt])
  @@index([matchId, scannedAt])
  @@index([scannedById])
  @@map("ticket_scans")
}

model Payout {
  id               String       @id @default(cuid())
  organizationId   String
  seasonId         String?
  grossAmount      Decimal      @db.Decimal(12, 2)
  commissionAmount Decimal      @db.Decimal(12, 2)
  netAmount        Decimal      @db.Decimal(12, 2)
  paidAt           DateTime?
  status           PayoutStatus @default(PENDING)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  season           Season?      @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([seasonId])
  @@map("payouts")
}

model PaymentConfig {
  id             String   @id @default(cuid())
  waveEnabled    Boolean  @default(false)
  waveApiKey     String?
  waveMerchantId String?
  omEnabled      Boolean  @default(false)
  omClientId     String?
  omClientSecret String?
  omMerchantKey  String?
  sandbox        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("payment_configs")
}

model AppSettings {
  id                    String   @id @default(cuid())
  applicationTitle      String   @default("Nawettane : Système de Billetterie digitale")
  contactLabel          String   @default("Contact :")
  contactPhone          String   @default("Téléphone :")
  developerName         String   @default("DICOTECH")
  developerWebsite      String   @default("Site web :")
  appDownloadAndroidUrl String?
  appDownloadIosUrl     String?
  appDownloadHelpText   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("app_settings")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@map("audit_logs")
}
